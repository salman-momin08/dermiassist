
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Rule to allow admins to list all users.
    match /users/{userId} {
      allow list: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Users can create, read, update, and delete their own user document.
      allow create, read, update, delete: if request.auth != null && request.auth.uid == userId;

      // A user can manage their own analyses subcollection.
      match /analyses/{analysisId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
