
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isDoctor() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // =====================================================================
    // User Profiles -> /users/{userId}
    // =====================================================================
    match /users/{userId} {
      // GET: Allows fetching a single user document.
      // 1. A user can read their own profile.
      // 2. Any authenticated user can read a doctor's profile.
      // 3. An admin can read any user's profile.
      allow get: if request.auth != null && (
                    isOwner(userId) ||
                    get(/databases/$(database)/documents/users/$(userId)).data.role == 'doctor' ||
                    isAdmin()
                  );

      // LIST: Allows querying the users collection.
      // Any authenticated user can list users, but the query in the app
      // specifically filters for doctors (role == 'doctor').
      // This is required for the "Find a Doctor" page to function.
      allow list: if request.auth != null;

      // CREATE:
      // A user can create their own document upon signup.
      allow create: if isOwner(userId);

      // UPDATE:
      // 1. A user can update their own profile.
      // 2. An admin can update any user's profile (e.g., for verification).
      allow update: if isOwner(userId) || isAdmin();

      // DELETE:
      // Only an admin can delete a user's account.
      allow delete: if isAdmin();

      // --- Analyses Subcollection -> /users/{userId}/analyses/{analysisId} ---
      match /analyses/{analysisId} {
        // Full access is granted only to the owner of the parent user document.
        allow read, write, delete: if isOwner(userId);
      }
    }

    // =====================================================================
    // Appointments -> /appointments/{appointmentId}
    // =====================================================================
    match /appointments/{appointmentId} {
      // READ, UPDATE, DELETE:
      // Access is granted if the user is the patient, the doctor, or an admin.
      allow read, update, delete: if request.auth != null && (
        request.auth.uid == resource.data.patientId ||
        request.auth.uid == resource.data.doctorId ||
        isAdmin()
      );

      // CREATE:
      // Any authenticated user can create an appointment request.
      allow create: if request.auth != null;
    }

    // =====================================================================
    // Chats -> /chats/{chatId}
    // =====================================================================
    // Chat documents are named '{patientId}_{doctorId}'
    match /chats/{chatId} {
      // A user can read/write to a chat if their UID is in the chatId.
      allow read, write: if request.auth != null && request.auth.uid in chatId.split('_');

      // --- Messages Subcollection -> /chats/{chatId}/messages/{messageId} ---
      match /messages/{messageId} {
        // Permissions are inherited from the parent chat document.
        allow read, write: if request.auth != null && request.auth.uid in chatId.split('_');
      }
    }
  }
}
