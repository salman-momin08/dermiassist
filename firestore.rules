
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to improve readability
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Users can read and update their own profile document.
      // Creation is handled during signup, so we don't allow it here.
      allow read, update: if isOwner(userId);
      
      // Deny users from creating or deleting their own top-level user document.
      allow create, delete: if false;

      // Rules for the 'analyses' subcollection within a user's document
      match /analyses/{analysisId} {
        // A user can create, read, and delete their own analysis reports.
        allow create, read, delete: if isOwner(userId);
        
        // Users cannot update an existing analysis report.
        allow update: if false;
      }
    }
  }
}
