
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and update their own user document, but not create or delete it through the app.
    // Creation is handled during signup, deletion via the Firebase console or admin SDK.
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;

      // Users can create, read, and delete their own analysis reports.
      match /analyses/{analysisId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
