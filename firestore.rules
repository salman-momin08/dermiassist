
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    function isAdmin() {
      // Check for existence of the user document and the role field.
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isDoctor() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Checks if the requesting doctor has a case file for the given patient.
    function isTheirPatient(patientId) {
        return isDoctor() && exists(/databases/$(database)/documents/doctorCases/$(request.auth.uid)/patients/$(patientId));
    }

    // =====================================================================
    // User Profiles -> /users/{userId}
    // =====================================================================
    match /users/{userId} {
      // GET: Allows fetching a single user document.
      // 1. A user can read their own profile.
      // 2. A doctor can read the profile of their own patient.
      // 3. Any authenticated user can read another doctor's profile.
      // 4. An admin can read any user's profile.
      allow get: if request.auth != null && (
                    isOwner(userId) ||
                    isTheirPatient(userId) ||
                    get(/databases/$(database)/documents/users/$(userId)).data.role == 'doctor' ||
                    isAdmin()
                  );

      // LIST: Allows querying the users collection.
      // Only doctors and admins can list users.
      // This is required for the "Find a Doctor" page and admin dashboards.
      allow list: if request.auth != null && (isDoctor() || isAdmin());

      // CREATE:
      // A user can create their own document upon signup.
      allow create: if isOwner(userId);

      // UPDATE:
      // 1. A user can update their own profile.
      // 2. An admin can update any user's profile (e.g., for verification).
      allow update: if isOwner(userId) || isAdmin();

      // DELETE:
      // Only an admin can delete a user's account.
      allow delete: if isAdmin();

      // --- Analyses Subcollection -> /users/{userId}/analyses/{analysisId} ---
      match /analyses/{analysisId} {
        // READ:
        // 1. A user can read their own analysis.
        // 2. A doctor can read the analysis of their own patient.
        allow read: if isOwner(userId) || isTheirPatient(userId);
        
        // WRITE, DELETE: Only the owner can modify their analyses.
        allow write, delete: if isOwner(userId);
      }
    }

    // =====================================================================
    // Appointments -> /appointments/{appointmentId}
    // =====================================================================
    match /appointments/{appointmentId} {
      // READ, UPDATE, DELETE:
      // Access is granted if the user is the patient, the doctor, or an admin.
      allow read, update, delete: if request.auth != null && (
        request.auth.uid == resource.data.patientId ||
        request.auth.uid == resource.data.doctorId ||
        isAdmin()
      );

      // CREATE:
      // Any authenticated user can create an appointment request.
      allow create: if request.auth != null;
    }

    // =====================================================================
    // Doctor Cases -> /doctorCases/{doctorId}/patients/{patientId}
    // =====================================================================
    match /doctorCases/{doctorId}/{path=**} {
        // A doctor can only access their own case files.
        allow read, write, delete: if isOwner(doctorId);
    }


    // =====================================================================
    // Chats -> /chats/{chatId}
    // =====================================================================
    // Chat documents are named '{patientId}_{doctorId}'
    match /chats/{chatId} {
      // A user can read/write to a chat if their UID is in the chatId.
      allow read, write: if request.auth != null && request.auth.uid in chatId.split('_');

      // --- Messages Subcollection -> /chats/{chatId}/messages/{messageId} ---
      match /messages/{messageId} {
        // Permissions are inherited from the parent chat document.
        allow read, write: if request.auth != null && request.auth.uid in chatId.split('_');
      }
    }
  }
}
