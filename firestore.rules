rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is an admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if a user is a doctor
    function isDoctor() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }
    
    // Helper function to check if the user is the owner of a document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Anyone can create their own user document during signup.
      allow create: if request.auth != null && request.auth.uid == userId;

      // Users can read their own profile.
      // Authenticated users can read doctor profiles.
      // Admins can read any profile.
      allow read: if isOwner(userId) || get(/databases/$(database)/documents/users/$(userId)).data.role == 'doctor' || isAdmin();

      // Users can update their own profile. Admins can update any profile (for verification, etc.).
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admins can delete user documents.
      allow delete: if isAdmin();

      // Rules for the 'analyses' subcollection nested under a user
      match /analyses/{analysisId} {
        // A user can only access their own analyses.
        allow read, write, delete: if isOwner(userId);
      }
    }

    // Rules for the 'appointments' collection
    match /appointments/{appointmentId} {
      // Allow querying the collection if the user is asking for their own appointments (as a patient or doctor).
      allow list: if request.auth != null && 
                    (request.query.limit <= 100) && // Add a reasonable limit
                    ((isDoctor() && request.query.filters[0].value == request.auth.uid) || 
                     (request.query.filters[0].value == request.auth.uid));

      // Allow getting a single document if the user is the patient or the doctor involved.
      allow get: if request.auth != null && (isOwner(resource.data.patientId) || isOwner(resource.data.doctorId) || isAdmin());

      // Any authenticated user can create an appointment.
      // The patient or doctor can update it.
      // Only the patient, doctor, or an admin can delete.
      allow write: if request.auth != null && 
                     (request.auth.uid == resource.data.patientId || request.auth.uid == resource.data.doctorId || isAdmin() || request.resource.data.patientId == request.auth.uid);
    }

    // Rules for the 'chats' collection
    // Chat documents are named '{patientId}_{doctorId}'
    match /chats/{chatId} {
      // A user can read/write to a chat if their UID is in the chatId.
      allow read, write: if request.auth != null && request.auth.uid in chatId.split('_');

      match /messages/{messageId} {
        // A user can read/write messages in a chat if their UID is in the chatId.
        allow read, write: if request.auth != null && request.auth.uid in chatId.split('_');
      }
    }
  }
}
