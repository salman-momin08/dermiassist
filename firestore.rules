rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Admins can do anything to any user document
      allow read, write, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Users can create their own document and read/update/delete their own document.
      // They cannot read other user documents.
      allow create: if request.auth.uid == userId;
      allow read, update, delete: if request.auth.uid == userId && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'admin';

      // Logged-in users can read analyses attached to their own user document.
      match /analyses/{analysisId} {
        allow read, write, delete: if request.auth.uid == userId;
      }
    }

    // Authenticated users (patients) can list doctors to find them.
    // The query in the app code ensures only verified doctors are returned.
    match /users/{userId} {
        allow list: if request.auth != null;
    }
  }
}