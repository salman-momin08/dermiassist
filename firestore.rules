rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isPatient() {
      return isUserAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'patient';
    }

    function isDoctor() {
      return isUserAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    function isAdmin() {
      return isUserAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isUserAuthenticated() && request.auth.uid == userId;
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Any authenticated user can create their own user document (for signup)
      allow create: if isUserAuthenticated() && request.auth.uid == userId;
      
      // Any authenticated user can read their own profile data.
      // Doctors can read the profile of a patient they have a case with.
      // Admins can read any user profile.
      // Any authenticated user can read a verified doctor's profile.
      allow get: if isOwner(userId) || isAdmin() || isDoctor() || (isUserAuthenticated() && get(/databases/$(database)/documents/users/$(userId)).data.verified == true);
      
      // An admin can list all users. Authenticated users can list verified doctors.
      allow list: if isAdmin() || (isUserAuthenticated() && request.query.get("where")[0][1] == "role" && request.query.get("where")[0][2] == "doctor" && request.query.get("where")[1][1] == "verified" && request.query.get("where")[1][2] == true);

      // A user can update their own profile data.
      // An admin can update any user's data (e.g., for verification).
      allow update: if isOwner(userId) || isAdmin();
      
      // Only an admin can delete a user document.
      allow delete: if isAdmin();

      // Rules for the 'analyses' subcollection within a user
      match /analyses/{analysisId} {
        // A user can create, read, update, and delete their own analysis reports.
        allow read, write, delete: if isOwner(userId);
      }
    }
    
    // Rules for the 'appointments' collection
    match /appointments/{appointmentId} {
      // Patients can create appointments.
      allow create: if isPatient();
      
      // A patient can read their own appointments.
      // A doctor can read appointments where they are the assigned doctor.
      // Admins can read any appointment.
      allow get: if isUserAuthenticated();
      allow list: if isUserAuthenticated(); // For queries by patientId or doctorId
      
      // Patients can cancel (update) their own pending appointments.
      // Doctors can update appointments assigned to them (e.g., confirm, add notes).
      allow update: if isPatient() || isDoctor();
      
      // Patients and Doctors can delete/cancel their appointments.
      allow delete: if isPatient() || isDoctor();
    }
    
    // Rules for the 'doctorCases' collection.
    // This collection links doctors to patients they have confirmed appointments with.
    match /doctorCases/{doctorId}/{subcollection}/{caseId} {
      // A doctor can create and update their own case files.
      allow write: if isOwner(doctorId);
      
      // A doctor can read their own case files.
      allow read: if isOwner(doctorId);
    }
  }
}